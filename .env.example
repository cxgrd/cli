CXGRD_LLM_PROVIDER=groq
CXGRD_LLM_MODEL=llama-3.3-70b-versatile

# Cloud (production)
CXGRD_AUTH_BASE_URL=https://cxgrd.com
CXGRD_PROMPT_API_URL=https://cxgrd.com/api/prompt

